{
  "name": "@graflethq/cli",
  "version": "0.1.0",
  "description": "Precomputed knowledge graphs of versioned library docs, for AI agents. Docs as a graph, not snippets.",
  "keywords": [
    "knowledge-graph",
    "docs",
    "documentation",
    "llm",
    "mcp",
    "ai",
    "rag",
    "graphrag",
    "context",
    "graphify"
  ],
  "license": "MIT",
  "author": "MD. MOHIBUR RAHMAN <mrpmohiburrahman@gmail.com>",
  "homepage": "https://github.com/graflethq/graflet",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/graflethq/graflet.git"
  },
  "type": "module",
  "bin": { "graflet": "dist/index.js" },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.1.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "4.1.10"
  }
}
