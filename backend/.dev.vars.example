# .dev.vars.example — committed template. Copy to .dev.vars and fill real values:
#   cp .dev.vars.example .dev.vars
# .dev.vars is gitignored; `wrangler dev` auto-loads it. Never commit real values.
# Tests do NOT use this file — they inject test values in vitest.config.ts.
# Format: dotenv KEY=value (quotes optional but safe for tokens).

# GitHub token that can read the PRIVATE KG repo (download broker, ticket 05).
PRIVATE_REPO_TOKEN="ghp_replace_me"

# GitHub OAuth App client secret — backend-only, never shipped in the CLI (ticket 03).
GITHUB_OAUTH_CLIENT_SECRET="replace_me"
