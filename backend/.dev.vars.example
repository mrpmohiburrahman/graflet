# .dev.vars.example — committed template. Copy to .dev.vars and fill real values.
#   cp .dev.vars.example .dev.vars
# .dev.vars is gitignored; wrangler dev auto-loads it. Never commit real values.
# Format is dotenv (KEY=value); quotes optional but safe for tokens.

# GitHub personal-access / installation token used to read the private repo.
PRIVATE_REPO_TOKEN="ghp_replace_me"

# GitHub OAuth App client secret (paired with your OAuth client ID).
GITHUB_OAUTH_CLIENT_SECRET="replace_me"
